print(f"Actor module: {actor}")
print(f"Forecaster module: {forecaster}")
print(f"Critic module: {critic}")

# Create the combined ActorCritic module
actor_critic_module = ActorCritic(actor, critic).to(device)

# Instantiate the ManualCollectionModule, wrapping the combined ActorCritic
# The exploration_type here will dictate how actions are sampled during collection
manual_policy = ManualCollectionModule(
