class ActorCritic(nn.Module):
    def __init__(self, actor_module, critic_module):
        super().__init__()
        self.actor = actor_module
        self.critic = critic_module

    def forward(self, tensordict: TensorDictBase) -> TensorDictBase:
        # Pass the tensordict through the actor to get actions and log_probs
        tensordict = self.actor(tensordict)
        # Pass the tensordict through the critic to get state_value
        # The critic TensorDictModule will extract its required inputs from the tensordict
        tensordict = self.critic(tensordict)
        return tensordict

