        'hidden_state_forecast' # From previous step's output
    ).reshape(num_envs_val * num_steps_val)

    # Run forecaster on collected data
    forecast_td = forecaster(forecaster_input_td.clone())
    predicted_forecast = forecast_td.get('forecast') # [num_envs * num_steps, 1, num_agents, forecast_horizon]

    # Correct the reshape using actual_node_feature_dim
    target_x_flat = target_x.reshape(num_envs_val * num_steps_val, num_agents, actual_node_feature_dim)

    # Calculate MSE loss for the forecaster (predicting immediate next step)
    # Take only the first step of the forecast for the simplified target
    # Squeeze out the extra dimension at index 1 from predicted_forecast before slicing
    forecaster_loss = nn.functional.mse_loss(predicted_forecast.squeeze(1)[:, :, 0], target_x_flat.squeeze(-1))

    # Optimize forecaster
    optimizer_forecaster.zero_grad()
    forecaster_loss.backward()
    optimizer_forecaster.step()
    scheduler_forecaster.step()

    # 3. PPO Optimization (Actor-Critic)
    for _ in range(num_epochs):
        # Shuffle and split data into minibatches
        # Manually create minibatches by shuffling indices
        flat_tensordict_data = tensordict_data.reshape(-1) # Flatten both num_envs and num_steps
        data_size = len(flat_tensordict_data)
        # Create a shuffled list of indices for minibatches
        shuffled_indices = torch.randperm(data_size, device=device)

        for start_idx in range(0, data_size, minibatch_size):
            end_idx = min(start_idx + minibatch_size, data_size)
            minibatch_indices = shuffled_indices[start_idx:end_idx]
            minibatch = flat_tensordict_data[minibatch_indices]

            # Compute PPO loss
            loss_td = loss_module(minibatch)

            actor_loss = loss_td['loss_critic']
            critic_loss = loss_td['loss_critic']
            entropy_loss = loss_td['loss_entropy']
            total_ppo_loss = actor_loss + critic_loss + entropy_loss

            # Optimize actor-critic
            optimizer_actor_critic.zero_grad()
            total_ppo_loss.backward()
            torch.nn.utils.clip_grad_norm_(loss_module.parameters(), max_grad_norm)
            optimizer_actor_critic.step()
    scheduler_actor_critic.step()

    # 4. Logging
    if i % log_interval == 0:
        mean_reward = tensordict_data['episode_reward'].mean().item()
        print(f"Iteration {i}/{total_frames // frames_per_batch}, Mean Reward: {mean_reward:.2f}")
        print(f"Forecaster Loss: {forecaster_loss.item():.4f}")

print("Training completed.")
