    num_action_categories, # Value 3
    dtype=torch.int64,
    device=device
)

# 3. Create the actor as an nn.Sequential module
# The first module is actor_policy_td_module, which takes observations and outputs logits + hidden_state.
# The second module is ProbabilisticTensorDictModule, which then takes the 'logits' from the previous step
# to create the distribution and sample actions.
actor = nn.Sequential(
    actor_policy_td_module, # Outputs TensorDict with 'logits' and 'hidden_state'
    ProbabilisticTensorDictModule(
        in_keys=["logits"], # This key refers to the output of the previous module
        out_keys=[("agents", "action"), ("agents", "action_log_prob")], # Outputs of the PTM
        distribution_class=Custom_MultiCategorical,
        distribution_kwargs={
            'nvec': correct_unbatched_nvec,
            'num_agents': num_agents, # Added
            'num_individual_actions_features': num_individual_actions_features # Added
        },
        dist_param_keys=['logits'], # Added this line as requested
        return_log_prob=True,
    ),
).to(device)

# 4. Create a separate TensorDictModule for the forecaster
forecaster = TensorDictModule(
    forecasting_module_nn,
    in_keys=forecaster_in_keys_list, # Explicitly pass the list of keys (now including 'hidden_state_forecast')
    out_keys=['forecast', 'hidden_state_forecast'] # ForecastingBase also outputs hidden state
).to(device)

# 5. Instantiate the ValueBase and wrap it in a TensorDictModule for the critic
critic = TensorDictModule(
    ValueBase(
        observation_spec=benv.observation_spec,
        hidden_rnn_dim=hidden_rnn_dim,
        gcn_hidden_dim=gcn_hidden_dim,
        num_agents=num_agents,
        input_x_dim=actual_node_feature_dim, # Use the actual feature dimension
        device=device
    ).to(device),
    in_keys=value_in_keys_list,
    out_keys=value_out_keys
).to(device)

