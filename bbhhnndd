# cell: P1rXecm_HZk8

import torch
import torch.distributions as tdists
from torch.distributions import Distribution

class Custom_MultiCategorical(Distribution):
    # nvec: A 1D tensor where each element is the number of categories for each individual action.
    # num_agents: The number of agents.
    # num_individual_actions_features: The number of features each agent can act on.
    def __init__(self, logits: torch.Tensor, nvec: torch.Tensor, *, num_agents: int, num_individual_actions_features: int, validate_args=None):
        self.batch_shape_prefix = logits.shape[:-1]
        self.nvec_from_spec = nvec.to(logits.device)
        self.num_agents = num_agents
        self.num_individual_actions_features = num_individual_actions_features

        if not torch.all(self.nvec_from_spec == self.nvec_from_spec[0]):
            raise ValueError("All categories in nvec_from_spec must be the same for Custom_MultiCategorical.")
        num_action_categories_per_feature = self.nvec_from_spec[0].item()

        self.total_num_categorical_dists = self.num_agents * self.num_individual_actions_features
        expected_logits_dim_per_env = self.total_num_categorical_dists * num_action_categories_per_feature

        if logits.shape[-1] != expected_logits_dim_per_env:
            raise ValueError(
                f"Expected logits trailing dim to be {expected_logits_dim_per_env} "
                f"(num_agents * num_features_per_agent * num_categories_per_feature), "
                f"but got {logits.shape[-1]}. Logits shape: {logits.shape}"
            )

        logits_reshaped = logits.view(*self.batch_shape_prefix, self.total_num_categorical_dists, num_action_categories_per_feature)

        self.dists = []
        for i in range(self.total_num_categorical_dists):
            self.dists.append(tdists.Categorical(logits=logits_reshaped[..., i, :], validate_args=validate_args))

        batch_shape = self.batch_shape_prefix
        event_shape = torch.Size([self.num_agents, self.num_individual_actions_features])

        super().__init__(batch_shape, event_shape, validate_args=validate_args)

    def log_prob(self, value):
        if value.shape[-2:] != self.event_shape:
            raise ValueError(f"Expected value to have trailing shape {self.event_shape}, but got {value.shape[-2:]}")

        log_probs_list = []
        value_reshaped = value.view(*self.batch_shape_prefix, self.total_num_categorical_dists)

        for i, d in enumerate(self.dists):
            log_probs_list.append(d.log_prob(value_reshaped[..., i]))

        return torch.stack(log_probs_list, dim=-1).sum(dim=-1)

    def entropy(self):
        entropy_list = [d.entropy() for d in self.dists]
        return torch.stack(entropy_list, dim=-1).sum(dim=-1)

    def sample(self, sample_shape=torch.Size()):
        samples_list = [d.sample(sample_shape) for d in self.dists]
        
        if sample_shape:
            effective_prefix_shape = sample_shape + self.batch_shape
        else:
            effective_prefix_shape = self.batch_shape

        # Stack to [effective_prefix_shape, total_num_categorical_dists]
        sampled_actions_flat = torch.stack(samples_list, dim=-1)
        
        # Reshape to [effective_prefix_shape, num_agents, num_individual_actions_features]
        sampled_actions = sampled_actions_flat.view(*effective_prefix_shape, self.num_agents, self.num_individual_actions_features)
        
        # Calculate log_prob for the sampled actions
        # The log_prob method already sums across the individual categorical actions and returns shape [..., 1] or [...]
        log_prob_of_sampled_actions = self.log_prob(sampled_actions)
        
        # Ensure log_prob_of_sampled_actions has a trailing dimension of 1 if it doesn't already
        # This is often expected by ProbabilisticTensorDictModule
        if log_prob_of_sampled_actions.ndim == len(effective_prefix_shape):
            log_prob_of_sampled_actions = log_prob_of_sampled_actions.unsqueeze(-1)

        return sampled_actions, log_prob_of_sampled_actions
