    if 'terminated' in tensordict_data.keys():
        print(f"  tensordict_data['terminated'].shape: {tensordict_data['terminated'].shape}")
    if 'truncated' in tensordict_data.keys():
        print(f"  tensordict_data['truncated'].shape: {tensordict_data['truncated'].shape}")

    if 'next' in tensordict_data.keys():
        if 'state_value' in tensordict_data['next'].keys():
            print(f"  tensordict_data['next', 'state_value'].shape: {tensordict_data['next', 'state_value'].shape}")
        if 'reward' in tensordict_data['next'].keys():
            print(f"  tensordict_data['next', 'reward'].shape: {tensordict_data['next', 'reward'].shape}")
        if 'done' in tensordict_data['next'].keys():
            print(f"  tensordict_data['next', 'done'].shape: {tensordict_data['next', 'done'].shape}")
        if 'terminated' in tensordict_data['next'].keys():
            print(f"  tensordict_data['next', 'terminated'].shape: {tensordict_data['next', 'terminated'].shape}")
        if 'truncated' in tensordict_data['next'].keys():
            print(f"  tensordict_data['next', 'truncated'].shape: {tensordict_data['next', 'truncated'].shape}")

    # 1. Compute GAE Advantages.
    # The adv_module (CustomGAE with value_network=critic) will now internally handle calculating
    # state_value and next.state_value and propagating hidden_state_value due to recurrent_state_keys.
    with torch.no_grad():
        # GAE with value_network will automatically compute state_value and next.state_value
        # and handle recurrent_state_keys, so no manual computation here.
        adv_module(tensordict_data)

    # 2. Extract input for forecaster and train it (supervised learning)
    # The forecaster predicts future 'x' (prices)
    # We need to get the current 'x' and compare against future 'x' from tensordict_data
    current_x = tensordict_data.get(('agents', 'data', 'x')) # [num_envs, num_steps, num_agents, actual_node_feature_dim]
    current_edge_index = tensordict_data.get(('agents', 'data', 'edge_index')) # [num_envs, num_steps, 2, num_edges]
    current_batch_nodes = tensordict_data.get(('agents', 'data', 'batch')) # [num_envs, num_steps, num_agents]
    current_time = tensordict_data.get(('agents', 'data', 'time')) # [num_envs, num_steps, 1]
    current_graph_attributes = tensordict_data.get(('agents', 'data', 'graph_attributes')) # [num_envs, num_steps, graph_attr_dim]

    # For forecaster training, we need actual future data to serve as targets
    # The 'next' key in tensordict_data holds the observations for the next step
    # However, the forecaster needs 'forecast_horizon' steps into the future.
    # This is a simplification and would need adjustment for a true multi-step forecast target.
    target_x = tensordict_data.get(('next', 'agents', 'data', 'x')) # [num_envs, num_steps, num_agents, actual_node_feature_dim]

    # Temporarily reshape tensordict_data to treat num_steps as batch for forecaster
    # (num_envs * num_steps) as batch size
    num_envs_val, num_steps_val = tensordict_data.batch_size # Use local variables to avoid shadowing globals
    forecaster_input_td = tensordict_data.select(
        ('agents', 'data', 'x'),
        ('agents', 'data', 'edge_index'),
        ('agents', 'data', 'batch'),
        ('agents', 'data', 'time'),
        ('agents', 'data', 'graph_attributes'),
        'hidden_state_forecast' # From previous step's output
    ).reshape(num_envs_val * num_steps_val)

    # Run forecaster on collected data
    forecast_td = forecaster(forecaster_input_td.clone())
    predicted_forecast = forecast_td.get('forecast') # [num_envs * num_steps, 1, num_agents, forecast_horizon]

    # Correct the reshape using actual_node_feature_dim
    target_x_flat = target_x.reshape(num_envs_val * num_steps_val, num_agents, actual_node_feature_dim)

    # Calculate MSE loss for the forecaster (predicting immediate next step)
    # Take only the first step of the forecast for the simplified target
    # Squeeze out the extra dimension at index 1 from predicted_forecast before slicing
    forecaster_loss = nn.functional.mse_loss(predicted_forecast.squeeze(1)[:, :, 0], target_x_flat.squeeze(-1))

    # Optimize forecaster
    optimizer_forecaster.zero_grad()
    forecaster_loss.backward()
    optimizer_forecaster.step()
    scheduler_forecaster.step()

    # 3. PPO Optimization (Actor-Critic)
    for _ in range(num_epochs):
        # Shuffle and split data into minibatches
        # Manually create minibatches by shuffling indices
        flat_tensordict_data = tensordict_data.reshape(-1) # Flatten both num_envs and num_steps
        data_size = len(flat_tensordict_data)
        # Create a shuffled list of indices for minibatches
        shuffled_indices = torch.randperm(data_size, device=device)

        for start_idx in range(0, data_size, minibatch_size):
            end_idx = min(start_idx + minibatch_size, data_size)
            minibatch_indices = shuffled_indices[start_idx:end_idx]
            minibatch = flat_tensordict_data[minibatch_indices]

            # Compute PPO loss
            loss_td = loss_module(minibatch)

            actor_loss = loss_td['loss_critic']
            critic_loss = loss_td['loss_critic']
            entropy_loss = loss_td['loss_entropy']
            total_ppo_loss = actor_loss + critic_loss + entropy_loss

            # Optimize actor-critic
            optimizer_actor_critic.zero_grad()
            total_ppo_loss.backward()
            torch.nn.utils.clip_grad_norm_(loss_module.parameters(), max_grad_norm)
            optimizer_actor_critic.step()
    scheduler_actor_critic.step()

    # 4. Logging
    if i % log_interval == 0:
        mean_reward = tensordict_data['episode_reward'].mean().item()
        print(f"Iteration {i}/{total_frames // frames_per_batch}, Mean Reward: {mean_reward:.2f}")
        print(f"Forecaster Loss: {forecaster_loss.item():.4f}")

print("Training completed.")
