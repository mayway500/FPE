class FuelpriceenvfeatureGraph:
    def __init__(self, data_path, num_agents=13, forecast_horizon=30, device=torch.device("cpu")):
        super().__init__()
        self.data_path = data_path
        self.num_agents = num_agents
        self.forecast_horizon = forecast_horizon
        self.device = device
        self._data_tensor = None
        self._load_data()

    def _load_data(self):
        print(f"Initializing FuelpriceenvfeatureGraph with data from: {self.data_path}")
        # Try to load the pre-processed data_tensor if it exists
        preprocessed_tensor_path = os.path.join(os.path.dirname(self.data_path), "data_tensor.pt")

        if os.path.exists(preprocessed_tensor_path):
            print(f"Loading _data_tensor from {preprocessed_tensor_path}")
            # Add _make_td and TensorDict to safe globals before loading
            torch.serialization.add_safe_globals([_make_td, TensorDict])
            self._data_tensor = torch.load(preprocessed_tensor_path)
            # Ensure it's on the correct device
            self._data_tensor = self._data_tensor.to(self.device)
            print("Data loaded from file.")
            return

        print("Pre-processed data_tensor not found. Processing from CSV...")

        # Load data from CSV
        df = pd.read_csv(self.data_path, index_col='Date', parse_dates=True)
        df.sort_index(inplace=True)

        # Drop columns that are entirely NaN
        df.dropna(axis=1, how='all', inplace=True)

        # Handle NaNs: forward fill, then back fill remaining (if any at start)
        df.fillna(method='ffill', inplace=True)
        df.fillna(method='bfill', inplace=True)

        # Ensure all columns are numeric
        for col in df.columns:
            df[col] = pd.to_numeric(df[col], errors='coerce') # Corrected: col to df[col]
        df.dropna(axis=1, how='all', inplace=True) # Drop columns that became all NaN after conversion

        # Filter out rows with any remaining NaNs
        df.dropna(inplace=True)

        if df.empty:
            raise ValueError("DataFrame is empty after cleaning. Cannot generate graph data.")

        # Z-score normalization across all features (columns)
        # Apply normalization only to the value columns
        numeric_cols = df.select_dtypes(include=np.number).columns
        df[numeric_cols] = df[numeric_cols].apply(zscore)

        # Determine features that represent fuel prices (agents)
        # Assuming columns starting with 'EER_' are fuel prices
        agent_features = [col for col in df.columns if col.startswith('EER_')]
        if len(agent_features) != self.num_agents:
            # For this example, let's just adjust num_agents if necessary, or raise error.s
            print(f"Warning: Expected {self.num_agents} agent features (fuel types), but found {len(agent_features)}. Adjusting num_agents.")
            self.num_agents = len(agent_features) # Update internal num_agents
            if self.num_agents == 0:
                raise ValueError("No agent features (fuel prices) found in data after processing.")

        # Create edge index: fully connected graph
        num_nodes = self.num_agents
        self_loops = [(i, i) for i in range(num_nodes)] # Add self-loops
        all_edges = [(i, j) for i in range(num_nodes) for j in range(num_nodes) if i != j] + self_loops
        edge_index = torch.tensor(all_edges, dtype=torch.long).t().contiguous()

        # Generate a sequence of graph observations
        all_graph_data = []
        for i in range(len(df)):
            current_date_data = df.iloc[i]

            # Node features (x): values of agent_features at current_date_data
            # Shape: [num_agents, input_x_dim] where input_x_dim is 1 here (the price itself)
            x = torch.tensor(current_date_data[agent_features].values, dtype=torch.float32).unsqueeze(1) # [num_agents, 1]

            # Graph attributes: use other features (non-agent features) as global attributes
            graph_attributes_values = current_date_data.drop(agent_features).values
            graph_attributes = torch.tensor(graph_attributes_values, dtype=torch.float32)

            # Time feature: represent the current time step (index in the dataframe)
            time_tensor = torch.tensor([i], dtype=torch.int64)

            # Define a dummy reward for agents. In a real RL env, this would come from the env step.
            # For data loading, we just need a placeholder of the correct shape.
            # Example: zero reward initially, or placeholder for a calculated reward.
            agent_rewards = torch.zeros(self.num_agents, 1, dtype=torch.float32)

            # Create a TensorDict for the current time step
            graph_td = TensorDict({
                "agents": TensorDict({
                    "data": TensorDict({
                        "x": x,
                        "edge_index": edge_index,
                        "batch": torch.zeros(num_nodes, dtype=torch.int64),
                        "time": time_tensor,
                        "graph_attributes": graph_attributes,
                    }, device=self.device),
                    "reward": agent_rewards,
                }, device=self.device)
            }, device=self.device)

            all_graph_data.append(graph_td)

        # Stack all individual time-step TensorDicts into a single TensorDict
        # The batch dimension will become the time dimension [num_total_time_steps]
        if all_graph_data:
            self._data_tensor = torch.stack(all_graph_data, dim=0).to(self.device)
        else:
            raise ValueError("No graph data was generated.")

        # Save the processed data_tensor for faster loading next time
        print(f"Saving _data_tensor to {preprocessed_tensor_path}")
        torch.save(self._data_tensor, preprocessed_tensor_path)

    def get_processed_data_tensor(self):
        """Returns the pre-processed data_tensor."""
        return self._data_tensor

    def get_graph_observation(self, time_idx=0) -> TensorDict:
        """
        Returns a single graph observation for a given time index.
        This method is primarily for testing and debugging.
        """
        if self._data_tensor is None:
            raise RuntimeError("Data not loaded. Call _load_data first.")
        if time_idx >= len(self._data_tensor) or time_idx < 0:
            raise IndexError(f"Time index {time_idx} out of bounds for data of length {len(self._data_tensor)}")

        return self._data_tensor[time_idx].clone() # Return a clone to avoid modifying the original data

