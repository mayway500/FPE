        # GCN output (per node) + time (1) + graph_attributes (graph_attr_dim)
        combined_feature_dim = gcn_hidden_dim + 1 + graph_attr_dim

        # Add GRU layer
        self.gru = nn.GRU(combined_feature_dim, hidden_rnn_dim, batch_first=False)

        # Forecasting head takes the GRU output and predicts future prices
        self.forecast_head = nn.Linear(hidden_rnn_dim, num_agents * forecast_horizon)

        print("ForecastingBase initialized.")

    def forward(self, x: torch.Tensor, edge_index: torch.Tensor, batch_nodes: torch.Tensor, time: torch.Tensor, graph_attributes: torch.Tensor, hidden_state_forecast_in: Optional[torch.Tensor] = None) -> Tuple[torch.Tensor, torch.Tensor]:
        # x can be [num_envs, num_agents, input_x_dim] or [num_envs, num_steps, num_agents, input_x_dim]

        if x.ndim == 3:
            num_envs_outer = x.shape[0]
            num_steps_outer = 1 # Corrected: Set num_steps_outer to 1 for single-step input
            x_processed = x.unsqueeze(1)
            edge_index_processed = edge_index.unsqueeze(1)
            time_processed = time.unsqueeze(1)
            graph_attributes_processed = graph_attributes.unsqueeze(1)
            if hidden_state_forecast_in is not None:
                hidden_state_forecast_in_processed = hidden_state_forecast_in.unsqueeze(1)
            else:
                hidden_state_forecast_in_processed = None
        elif x.ndim == 4:
            num_envs_outer = x.shape[0]
            num_steps_outer = x.shape[1]
            x_processed = x
            edge_index_processed = edge_index
            time_processed = time
            graph_attributes_processed = graph_attributes
            hidden_state_forecast_in_processed = hidden_state_forecast_in
        else:
            raise ValueError(f"Unexpected input 'x' dimensions: {x.ndim}")

        effective_batch_size = num_envs_outer * num_steps_outer

        # Prepare GCN inputs
        x_gcn = x_processed.view(effective_batch_size * self.num_agents, self.input_x_dim)
        # Clone x_gcn to prevent vmap related memory issues with torch_geometric
        x_gcn_cloned = x_gcn.clone()

        batch_tg = torch.arange(effective_batch_size, device=self.device).repeat_interleave(self.num_agents)

        edge_index_flattened = edge_index_processed.view(effective_batch_size, 2, -1)
        node_offsets = (torch.arange(effective_batch_size, device=self.device) * self.num_agents).unsqueeze(1).unsqueeze(1)
        edge_index_tg = (edge_index_flattened + node_offsets).view(2, -1)
        # Clone edge_index_tg to prevent vmap related memory issues with torch_geometric
        edge_index_tg_cloned = edge_index_tg.clone().contiguous() # Added .contiguous()

        # GCN forward pass
        x_gcn = self.gcn_conv1(x_gcn_cloned, edge_index_tg_cloned)
        x_gcn = x_gcn.relu()
        x_gcn = self.gcn_conv2(x_gcn, edge_index_tg_cloned)
        x_gcn = x_gcn.relu()

        # Global pooling
        graph_embeddings = global_mean_pool(x_gcn, batch_tg)

        # Combine features for GRU input
        time_flattened = time_processed.view(effective_batch_size, 1).float()
        graph_attributes_flattened = graph_attributes_processed.view(effective_batch_size, -1)
        combined_features = torch.cat([graph_embeddings, time_flattened, graph_attributes_flattened], dim=-1)

        # Prepare for GRU: input is [seq_len, batch_size, input_size]
        gru_input = combined_features.unsqueeze(0)

        # Handle hidden state for GRU
        if hidden_state_forecast_in_processed is not None:
            h_in_forecast = hidden_state_forecast_in_processed.view(1, effective_batch_size, self.hidden_rnn_dim)
        else:
            h_in_forecast = torch.zeros(1, effective_batch_size, self.hidden_rnn_dim, device=self.device)

        gru_output_forecast, h_out_forecast = self.gru(gru_input, h_in_forecast)

        # Forecasting head output from GRU output
        forecast_flat = self.forecast_head(gru_output_forecast.squeeze(0)) # [effective_batch_size, num_agents * forecast_horizon]

        # Reshape to [effective_batch_size, num_agents, forecast_horizon]
        forecast = forecast_flat.view(effective_batch_size, self.num_agents, self.forecast_horizon)
        # Reshape to [num_envs_outer, num_steps_outer, num_agents, forecast_horizon]
        forecast_reshaped = forecast.view(num_envs_outer, num_steps_outer, self.num_agents, self.forecast_horizon)

        # Reshape h_out_forecast back to [num_envs_outer, num_steps_outer, hidden_rnn_dim]
        h_out_forecast_reshaped = h_out_forecast.squeeze(0).view(num_envs_outer, num_steps_outer, self.hidden_rnn_dim)

        return forecast_reshaped, h_out_forecast_reshaped

class CombinedPolicyForecastingBase(nn.Module):
    def __init__(self, observation_spec, action_spec, hidden_rnn_dim, gcn_hidden_dim, num_agents, input_x_dim, num_action_categories, num_individual_actions_features, forecast_horizon, device):
        super().__init__()
        self.policy_module = PolicyBase(
            observation_spec=observation_spec,
            action_spec=action_spec,
            hidden_rnn_dim=hidden_rnn_dim,
            gcn_hidden_dim=gcn_hidden_dim,
            num_agents=num_agents,
            input_x_dim=input_x_dim,
            num_action_categories=num_action_categories,
            num_individual_actions_features=num_individual_actions_features,
            device=device
        )
        self.forecasting_module = ForecastingBase(
            observation_spec=observation_spec,
            forecast_horizon=forecast_horizon,
            gcn_hidden_dim=gcn_hidden_dim,
            num_agents=num_agents,
            input_x_dim=input_x_dim,
            hidden_rnn_dim=hidden_rnn_dim, # Pass hidden_rnn_dim to ForecastingBase
            device=device
        )
        print("CombinedPolicyForecastingBase initialized.")

    def forward(self, tensordict: TensorDictBase) -> TensorDictBase:
        # Policy module computes action logits and updates hidden state
        # Need to call policy_module with individual keys from tensordict
        x = tensordict.get(('agents', 'data', 'x'))
        edge_index = tensordict.get(('agents', 'data', 'edge_index'))
        batch_nodes = tensordict.get(('agents', 'data', 'batch'))
        time = tensordict.get(('agents', 'data', 'time'))
        graph_attributes = tensordict.get(('agents', 'data', 'graph_attributes'))
        hidden_state_in = tensordict.get('hidden_state', None)

        action_logits, h_out = self.policy_module(
            x=x,
            edge_index=edge_index,
            batch_nodes=batch_nodes,
            time=time,
            graph_attributes=graph_attributes,
            hidden_state_in=hidden_state_in
        )
        tensordict.set('action_logits', action_logits)
        tensordict.set('hidden_state', h_out)

        # Forecasting module computes forecasts
        hidden_state_forecast_in = tensordict.get('hidden_state_forecast', None)
        forecast, h_out_forecast = self.forecasting_module(
            x=x,
            edge_index=edge_index,
            batch_nodes=batch_nodes,
            time=time,
            graph_attributes=graph_attributes,
            hidden_state_forecast_in=hidden_state_forecast_in
        )
        tensordict.set('forecast', forecast)
        tensordict.set('hidden_state_forecast', h_out_forecast)

        return tensordict


