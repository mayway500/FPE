class AnFuelpriceEnv(EnvBase):
    """
    A custom environment for fuel price prediction using graph observations.
    Inherits from EnvBase to integrate with TorchRL.
    """
    def __init__(
        self,
        data_tensor: TensorDict,
        num_envs: int,
        seed: int,
        device: torch.device,
        episode_length: int,
        num_agents: int,
        batch_size: torch.Size = None,
        allow_repeat_data: bool = True,
        **kwargs,
    ):
        super().__init__(batch_size=batch_size, device=device, **kwargs)

        self.data_tensor = data_tensor.to(device) # Move the entire data_tensor to the specified device
        self.num_envs = num_envs
        self.seed = seed
        self.episode_length = episode_length
        self.num_agents = num_agents # Now correctly reflects the actual number of agents
        self.allow_repeat_data = allow_repeat_data
        self.batch_size = batch_size # Set batch_size here

        # Hyperparameters specific to action space (from problem description)
        self.num_individual_actions_features = globals().get('num_individual_actions_features', 13) # Number of features each agent can act on
        self.num_action_categories = globals().get('num_action_categories', 3) # Number of discrete action choices per feature

        # Extract dimensions from the data_tensor for spec creation
        if self.data_tensor.batch_size and len(self.data_tensor.batch_size) > 0:
            self.num_total_time_steps = self.data_tensor.batch_size[0]
        else:
            raise ValueError("data_tensor must have a batch dimension representing time steps.")

        # Safely get properties from the first time step's data for spec definition
        first_time_step_data = self.data_tensor[0].get(('agents', 'data'))
        if first_time_step_data is None:
            raise ValueError("data_tensor does not contain ('agents', 'data') key at the first time step.")

        # Ensure these are not None before accessing shape
        x_tensor = first_time_step_data.get('x')
        edge_index_tensor = first_time_step_data.get('edge_index')
        graph_attributes_tensor = first_time_step_data.get('graph_attributes')

        if x_tensor is None or x_tensor.ndim < 2:
            raise ValueError("Node features 'x' not found or has incorrect dimensions in data_tensor.")
        if edge_index_tensor is None or edge_index_tensor.ndim < 1:
            raise ValueError("Edge index 'edge_index' not found or has incorrect dimensions in data_tensor.")
        if graph_attributes_tensor is None:
            raise ValueError("Graph attributes 'graph_attributes' not found in data_tensor.")

        # This is the feature dimension of the input `x` for GCNs
        self.input_x_feature_dim = x_tensor.shape[-1]
        self.num_edges_single_graph = edge_index_tensor.shape[-1]
        self.graph_attr_dim = graph_attributes_tensor.shape[-1]

        self._set_seed(seed)
        self._set_specs()
        print(f"AnFuelpriceEnv initialized with {self.num_envs} parallel environments.")
        print(f"Data tensor device: {self.data_tensor.device}")

    def _set_seed(self, seed: Optional[int] = None) -> None:
        # Set the seed for the environment's random number generator
        # This method is required by EnvBase
        if seed is None:
            seed = torch.empty((), dtype=torch.int64).random_().item()
        self.rng = torch.Generator(device=self.device)
        self.rng.manual_seed(seed)
        self.seed = seed

    def _set_specs(self):
        # Define the shapes for a single environment instance (without batch dimension)
        x_item_shape = torch.Size([self.num_agents, self.input_x_feature_dim])
        edge_index_item_shape = torch.Size([2, self.num_edges_single_graph])
        batch_item_shape = torch.Size([self.num_agents]) # This 'batch' is for graph nodes, not env batch
        time_item_shape = torch.Size([1])
        graph_attributes_item_shape = torch.Size([self.graph_attr_dim])

        # Define observation_spec for a single environment instance
        # Include 'step_count' as it's returned by _reset and _step
        single_observation_spec = Composite(
            {
                ("agents", "data", "x"): Unbounded(
                    shape=x_item_shape, dtype=torch.float32, device=self.device
                ),
                ("agents", "data", "edge_index"): Unbounded(
                    shape=edge_index_item_shape, dtype=torch.long, device=self.device
                ),
                ("agents", "data", "batch"): Unbounded(
                    shape=batch_item_shape, dtype=torch.int64, device=self.device
                ),
                ("agents", "data", "time"): Unbounded(
                     shape=time_item_shape, dtype=torch.int64, device=self.device
                ),
                ("agents", "data", "graph_attributes"): Unbounded(
                     shape=graph_attributes_item_shape, dtype=torch.float32, device=self.device
                ),
                "step_count": Unbounded(
                    shape=torch.Size([]), dtype=torch.int64, device=self.device
                ),
                # REMOVED: done, terminated, and truncated from observation_spec to avoid collision
            },
            device=self.device
        )

         # Define action_spec for a single environment instance
        # Redefine the action space to be flattened for the MultiCategorical spec
        total_independent_categorical_choices = self.num_agents * self.num_individual_actions_features # 13 * 3 = 39
        nvec_for_spec = torch.full(
            (total_independent_categorical_choices,),
            self.num_action_categories, # Value 3
            dtype=torch.int64,
            device=self.device
        )
        # The shape of the action tensor *as seen by the spec* must be 1D, matching nvec's shape.
        action_spec_shape = torch.Size([total_independent_categorical_choices]) # Shape [39]

        Unbatched_action_spec = Composite(
              {('agents','action'): MultiCategorical(
                                                      dtype=torch.int64,
                                                      device=self.device,
                                                      nvec=nvec_for_spec,
                                                      shape=action_spec_shape # Changed shape to match nvec.shape
                                                      )},
              batch_size=[], # Unbatched environment has no batch size at the root
              device=self.device
            )

        # Expand the unbatched action spec by the environment's batch_size to get the final action_spec
        self.action_spec = Unbatched_action_spec.expand(self.batch_size)

        # Reward Spec for a single environment instance:
        # The base env's _step will now return a root-level 'reward' for GAE.
        # It will also keep the nested ('agents', 'reward') for multi-agent specific logic if needed.
        single_reward_spec = Unbounded(
            shape=torch.Size([1,1]), # Single scalar reward per environment per step
            dtype=torch.float32,
            device=self.device
        )
        self.reward_spec = Composite({
            'reward': single_reward_spec, # Root-level reward for GAE
            'agents': {
                'reward': Unbounded( # Agent-level reward, one scalar per agent (for potential future use)
                    shape=torch.Size([self.num_agents, 1,1]),
                    dtype=torch.float32,
                    device=self.device
                )
            }
        }).expand(self.batch_size)

        # Done, Terminated, Truncated Specs for a single environment instance:
        # Modified: Set shape to torch.Size([1]) to match reward and value function outputs
        single_done_spec = Unbounded(
            shape=torch.Size([1,1]), dtype=torch.bool, device=self.device
        )
        single_terminated_spec = Unbounded(
            shape=torch.Size([1,1]), dtype=torch.bool, device=self.device
        )
        single_truncated_spec = Unbounded(
            shape=torch.Size([1,1]), dtype=torch.bool, device=self.device
        )

        # Now, expand these single-environment specs by the environment's batch_size
        self.observation_spec = single_observation_spec.expand(self.batch_size)
        # self.action_spec is already set above to match _step output
        self.done_spec = single_done_spec.expand(self.batch_size)
        self.terminated_spec = single_terminated_spec.expand(self.batch_size)
        self.truncated_spec = single_truncated_spec.expand(self.batch_size)


    def _reset(self, tensordict: TensorDictBase = None, **kwargs) -> TensorDictBase:
        if tensordict is None:
            tensordict = TensorDict({}, batch_size=self.batch_size, device=self.device)

        # Initialize current time index for each parallel environment
        if self.allow_repeat_data:
            # Randomly select a starting index for each environment
            max_start_idx = max(0, self.num_total_time_steps - self.episode_length)
            if max_start_idx < 0:
                max_start_idx = 0
            self.index_in_data = torch.randint(
                0,
                max_start_idx + 1,
                self.batch_size,
                generator=self.rng,
                device=self.device,
            )
        else:
            # If data repeat is not allowed, ensure unique segments per environment if possible
            max_start_idx = max(0, self.num_total_time_steps - self.episode_length)
            self.index_in_data = torch.zeros(self.batch_size, dtype=torch.long, device=self.device)

        # Get the observation for the current index
        current_data_td = self.data_tensor[self.index_in_data] # Selects a slice for each env from the time dim

        # Populate tensordict with initial observations
        tensordict.set(("agents", "data", "x"), current_data_td.get(("agents", "data", "x")))
        tensordict.set(("agents", "data", "edge_index"), current_data_td.get(("agents", "data", "edge_index")))
        tensordict.set(("agents", "data", "batch"), current_data_td.get(("agents", "data", "batch")))
        tensordict.set(("agents", "data", "time"), current_data_td.get(("agents", "data", "time")))
        tensordict.set(("agents", "data", "graph_attributes"), current_data_td.get(("agents", "data", "graph_attributes")))

        # Removed: Initialize root-level reward. For reset, this should typically be 0.
        # tensordict.set("reward", torch.zeros(self.num_envs, 1, dtype=torch.float32, device=self.device))

        # Removed: Keep agent-level reward for completeness if desired, but not directly used by GAE now
        # tensordict.set(("agents", "reward"), current_data_td.get(("agents", "reward")))

        tensordict.set("step_count", torch.zeros(self.num_envs, dtype=torch.int64, device=self.device))

        # REMOVED: done, terminated, and truncated from _reset method as they should not be explicitly returned
        # tensordict.set("done", torch.zeros( self.num_envs, 1, dtype=torch.bool, device=self.device))
        # tensordict.set("terminated", torch.zeros( self.num_envs, 1, dtype=torch.bool, device=self.device))
        # tensordict.set("truncated", torch.zeros( self.num_envs, 1, dtype=torch.bool, device=self.device))

        return tensordict

    def _step(self, tensordict: TensorDictBase) -> TensorDictBase:
        action = tensordict.get(("agents", "action"))
        # Action from policy will be flattened ([num_envs, total_independent_categorical_choices])
        # Reshape it back to [num_envs, num_agents, num_individual_actions_features]
        # The action itself is not used for reward calculation in this simplified setup, but kept for context.
        # action_reshaped = action.view(self.num_envs, self.num_agents, self.num_individual_actions_features)

        # Get current state's price data for reward calculation
        current_x = tensordict.get(("agents", "data", "x")) # Shape: [num_envs, num_agents, input_x_dim]

        # Increment the time index for each environment
        self.index_in_data += 1

        # Increment step_count for each environment
        current_step_count = tensordict.get(("step_count"))
        new_step_count = current_step_count + 1

        # Determine if the episode is done for each environment
        truncated = (new_step_count >= self.episode_length - 1) # [num_envs]

        # Check if we are out of data for each environment individually
        out_of_data = self.index_in_data >= self.num_total_time_steps # [num_envs]

        if not self.allow_repeat_data:
            terminated = out_of_data
        else:
            max_start_idx = max(0, self.num_total_time_steps - self.episode_length)
            if max_start_idx < 0:
                max_start_idx = 0

            new_indices = torch.randint(
                0,
                max_start_idx + 1,
                (self.num_envs,),
                generator=self.rng,
                device=self.device
            )
            self.index_in_data = torch.where(
                out_of_data,
                new_indices,
                self.index_in_data
            )
            terminated = torch.zeros_like(truncated, dtype=torch.bool) # [num_envs]

        done = terminated | truncated # [num_envs]


        # Get the observation for the new time index for each environment
        clamped_indices = torch.clamp(self.index_in_data, max=self.num_total_time_steps - 1)
        next_data_td = self.data_tensor[clamped_indices]

        # Get next state's price data
        next_x = next_data_td.get(("agents", "data", "x")) # Shape: [num_envs, num_agents, input_x_dim]

        # --- New Reward Calculation Logic ---
        price_change_threshold = 0.05 # User-defined threshold
        positive_reward_value = 0.1 # Small positive reward for stable prices
        penalty_scale = 1.0 # Scaling factor for negative reward

        # Calculate absolute price change for each agent
        # current_x and next_x have shape [num_envs, num_agents, 1]
        abs_price_change = (next_x - current_x).abs()

        # Initialize agent-level rewards
        agent_rewards = torch.zeros_like(abs_price_change, dtype=torch.float32)

        # Apply reward logic: positive for small changes, negative for large changes
        # Use boolean masking for vectorized operations
        stable_price_mask = (abs_price_change < price_change_threshold)
        agent_rewards[stable_price_mask] = positive_reward_value
        agent_rewards[~stable_price_mask] = -penalty_scale * abs_price_change[~stable_price_mask]

        # Calculate total reward for each environment by summing agent-level rewards
        total_reward_this_step = agent_rewards.sum(dim=-2) # Sum over agents, result [num_envs, 1]

        # Populate tensordict_out with next observations, rewards, and updated step_count
        tensordict_out = TensorDict({
            ("agents", "data", "x"): next_data_td.get(("agents", "data", "x")),
            ("agents", "data", "edge_index"): next_data_td.get(("agents", "data", "edge_index")),
            ("agents", "data", "batch"): next_data_td.get(("agents", "data", "batch")),
            ("agents", "data", "time"): next_data_td.get(("agents", "data", "time")),
            ("agents", "data", "graph_attributes"): next_data_td.get(("agents", "data", "graph_attributes")),
            "reward": total_reward_this_step.unsqueeze(-1), # Root-level reward for GAE, shape [num_envs, 1,1]
            ("agents", "reward"): agent_rewards, # Agent-level reward, shape [num_envs, num_agents, 1]
            "step_count": new_step_count,
            "done": done.unsqueeze(-1).unsqueeze(-1), # Ensure shape is [num_envs, 1,1]
            "terminated": terminated.unsqueeze(-1).unsqueeze(-1), # Ensure shape is [num_envs, 1,1]
            "truncated": truncated.unsqueeze(-1).unsqueeze(-1), # Ensure shape is [num_envs, 1,1]
        } , batch_size=self.batch_size, device=self.device)

        return tensordict_out


