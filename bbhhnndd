        self.hidden_rnn_dim = hidden_rnn_dim
        self.device = device

        # Extract graph_attr_dim from observation_spec
        graph_attr_dim = observation_spec["agents", "data", "graph_attributes"].shape[-1]

        # GCN output (per node) + time (1) + graph_attributes (graph_attr_dim)
        combined_feature_dim = gcn_hidden_dim + 1 + graph_attr_dim
        self.gru = nn.GRU(combined_feature_dim, hidden_rnn_dim, batch_first=False) # GRU expects (seq_len, batch, input_size)

        # Action head outputs logits for each action category for each agent and each action feature
        # Total output size: num_agents * num_individual_actions_features * num_action_categories
        self.action_head = nn.Linear(hidden_rnn_dim, num_agents * num_individual_actions_features * num_action_categories)

        print("PolicyBase initialized.")

    def forward(self, x: torch.Tensor, edge_index: torch.Tensor, batch_nodes: torch.Tensor, time: torch.Tensor, graph_attributes: torch.Tensor, hidden_state_in: Optional[torch.Tensor] = None) -> Tuple[torch.Tensor, torch.Tensor]:
        # x can be [num_envs, num_agents, input_x_dim] or [num_envs, num_steps, num_agents, input_x_dim]

        if x.ndim == 3: # Case: [num_envs, num_agents, input_x_dim]
            num_envs_outer = x.shape[0]
            num_steps_outer = 1 # Corrected: Set num_steps_outer to 1 for single-step input
            # Unsqueeze to add the 'num_steps' dimension for consistent processing later
            x_processed = x.unsqueeze(1)
            edge_index_processed = edge_index.unsqueeze(1)
            time_processed = time.unsqueeze(1)
            graph_attributes_processed = graph_attributes.unsqueeze(1)
            if hidden_state_in is not None:
                hidden_state_in_processed = hidden_state_in.unsqueeze(1)
            else:
                hidden_state_in_processed = None
        elif x.ndim == 4: # Case: [num_envs, num_steps, num_agents, input_x_dim]
            num_envs_outer = x.shape[0]
            num_steps_outer = x.shape[1]
            x_processed = x
            edge_index_processed = edge_index
            time_processed = time
            graph_attributes_processed = graph_attributes
            hidden_state_in_processed = hidden_state_in
        else:
            raise ValueError(f"Unexpected input 'x' dimensions: {x.ndim}")

        # Now all inputs have shape [num_envs_outer, num_steps_outer, ...]
        effective_batch_size = num_envs_outer * num_steps_outer

        # Prepare GCN inputs
        x_gcn = x_processed.view(effective_batch_size * self.num_agents, self.input_x_dim)
        # Clone x_gcn to prevent vmap related memory issues with torch_geometric
        x_gcn_cloned = x_gcn.clone()

        # Create batch tensor for global_mean_pool
        batch_tg = torch.arange(effective_batch_size, device=self.device).repeat_interleave(self.num_agents)

        # Prepare edge_index for GCN by offsetting node indices for each graph
        edge_index_flattened = edge_index_processed.view(effective_batch_size, 2, -1)
        node_offsets = (torch.arange(effective_batch_size, device=self.device) * self.num_agents).unsqueeze(1).unsqueeze(1)
        edge_index_tg = (edge_index_flattened + node_offsets).view(2, -1)
        # Clone edge_index_tg to prevent vmap related memory issues with torch_geometric
        edge_index_tg_cloned = edge_index_tg.clone().contiguous() # Added .contiguous()

        # GCN forward pass
        x_gcn = self.gcn_conv1(x_gcn_cloned, edge_index_tg_cloned)
        x_gcn = x_gcn.relu()
        x_gcn = self.gcn_conv2(x_gcn, edge_index_tg_cloned) # edge_index_tg_cloned can be reused here
        x_gcn = x_gcn.relu()

        # Global pooling to get graph-level representations: [effective_batch_size, gcn_hidden_dim]
        graph_embeddings = global_mean_pool(x_gcn, batch_tg)

        # Combine graph embeddings with time and global graph attributes
        time_flattened = time_processed.view(effective_batch_size, 1).float()
        graph_attributes_flattened = graph_attributes_processed.view(effective_batch_size, -1)
        combined_features = torch.cat([graph_embeddings, time_flattened, graph_attributes_flattened], dim=-1)

        # Prepare for GRU: input is [seq_len, batch_size, input_size]
        gru_input = combined_features.unsqueeze(0)

        # Handle hidden state for GRU
        if hidden_state_in_processed is not None:
            # hidden_state_in_processed is [num_envs_outer, num_steps_outer, hidden_rnn_dim]
            h_in_gru = hidden_state_in_processed.view(1, effective_batch_size, self.hidden_rnn_dim)
        else:
            h_in_gru = torch.zeros(1, effective_batch_size, self.hidden_rnn_dim, device=self.device)

        gru_output, h_out = self.gru(gru_input, h_in_gru)

        # Action logits from GRU output
        action_logits_flat = self.action_head(gru_output.squeeze(0)) # [effective_batch_size, total_logits_dim]
        action_logits_reshaped = action_logits_flat.view(num_envs_outer, num_steps_outer, -1)

        # Reshape h_out back to [num_envs_outer, num_steps_outer, hidden_rnn_dim]
        h_out_reshaped = h_out.squeeze(0).view(num_envs_outer, num_steps_outer, self.hidden_rnn_dim)

        return action_logits_reshaped, h_out_reshaped

