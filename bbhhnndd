        },
        dist_param_keys=['logits'], # <--- CRUCIAL: Explicitly specify 'logits' as the distribution parameter
        return_log_prob=True,
    ),
).to(device)


# 4. Create a separate TensorDictModule for the forecaster
forecaster = TensorDictModule(
