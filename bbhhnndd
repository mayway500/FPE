# 1. Instantiate the PolicyBase (for actor) and ForecastingBase (for separate forecast module)
policy_module_nn = PolicyBase(
    observation_spec=benv.observation_spec,
    action_spec=benv.action_spec,
    hidden_rnn_dim=hidden_rnn_dim,
    gcn_hidden_dim=gcn_hidden_dim,
    num_agents=num_agents,
    input_x_dim=actual_node_feature_dim, # Use the actual feature dimension
    num_action_categories=num_action_categories,
    num_individual_actions_features=num_individual_actions_features,
    device=device
).to(device)

forecasting_module_nn = ForecastingBase(
    observation_spec=benv.observation_spec,
    forecast_horizon=forecast_horizon,
    gcn_hidden_dim=gcn_hidden_dim,
    num_agents=num_agents,
    input_x_dim=actual_node_feature_dim, # Use the actual feature dimension
    hidden_rnn_dim=hidden_rnn_dim, # Pass hidden_rnn_dim to ForecastingBase
    device=device
).to(device)

# 2. Wrap policy_module_nn in a TensorDictModule that outputs logits AND hidden_state
actor_policy_td_module = TensorDictModule(
    module=policy_module_nn,
    in_keys=policy_in_keys_list, # This includes 'hidden_state' as input
    out_keys=['logits', 'hidden_state'] # This needs to output 'hidden_state' as well
).to(device)

# Construct the correct 1D nvec for Custom_MultiCategorical
# It should be a 1D tensor where each element is the number of categories for each individual action
correct_unbatched_nvec = torch.full(
    (num_agents * num_individual_actions_features,),
    num_action_categories, # Value 3
    dtype=torch.int64,
    device=device
)

# 3. Create the actor as an nn.Sequential module
# The first module is actor_policy_td_module, which takes observations and outputs logits + hidden_state.
# The second module is ProbabilisticTensorDictModule, which then takes the 'logits' from the previous step
# to create the distribution and sample actions.
actor = nn.Sequential(
    actor_policy_td_module, # Outputs TensorDict with 'logits' and 'hidden_state'
    ProbabilisticTensorDictModule(
        in_keys=["logits"], # This key refers to the output of the previous module
        out_keys=[("agents", "action"), ("agents", "action_log_prob")], # Outputs of the PTM
        distribution_class=Custom_MultiCategorical,
        distribution_kwargs={
            'nvec': correct_unbatched_nvec,
            'num_agents': num_agents, # Added
            'num_individual_actions_features': num_individual_actions_features # Added
        },
        return_log_prob=True,
    ),
).to(device)

# 4. Create a separate TensorDictModule for the forecaster
forecaster = TensorDictModule(
    forecasting_module_nn,
    in_keys=forecaster_in_keys_list, # Explicitly pass the list of keys (now including 'hidden_state_forecast')
    out_keys=['forecast', 'hidden_state_forecast'] # ForecastingBase also outputs hidden state
).to(device)

# 5. Instantiate the ValueBase and wrap it in a TensorDictModule for the critic
critic = TensorDictModule(
    ValueBase(
        observation_spec=benv.observation_spec,
        hidden_rnn_dim=hidden_rnn_dim,
        gcn_hidden_dim=gcn_hidden_dim,
        num_agents=num_agents,
        input_x_dim=actual_node_feature_dim, # Use the actual feature dimension
        device=device
    ).to(device),
    in_keys=value_in_keys_list,
    out_keys=value_out_keys
).to(device)

print("Modules (actor, forecaster, and critic) initialized successfully.")
print(f"Actor module: {actor}")
print(f"Forecaster module: {forecaster}")
print(f"Critic module: {critic}")

# Create the combined ActorCritic module
actor_critic_module = ActorCritic(actor, critic).to(device)

# Instantiate the ManualCollectionModule, wrapping the combined ActorCritic
# The exploration_type here will dictate how actions are sampled during collection
manual_policy = ManualCollectionModule(
    actor_critic_module,
    exploration_type=ExplorationType.RANDOM # Or ExplorationType.MODE for deterministic actions
).to(device)

# Create the collector using the transformed environment and the manual policy
collector = SyncDataCollector(
    benv, # Transformed environment
    manual_policy, # Our manual policy wrapper which contains actor and critic
    frames_per_batch=frames_per_batch,
    total_frames=total_frames,
    device=device,
    storing_device=device
    # recurrent_state_keys={'hidden_state': 'hidden_state', 'hidden_state_value': 'hidden_state_value'} # Removed as it causes TypeError
)

print("Collector created successfully.")
print(collector)

adv_module = CustomGAE(
    gamma=gamma,
    lmbda=lmbda,
    value_network=critic, # Pass the critic module as the value network
    reward_key='reward', # Changed to use the root-level 'reward' from environment
    recurrent_state_keys={'hidden_state_value': 'hidden_state_value'} # This will now be handled by CustomGAE
).to(device)

loss_module = ClipPPOLoss(
    actor=actor, # Directly pass the ProbabilisticActor
    critic=critic,
    clip_epsilon=clip_epsilon,
    loss_critic_type='squared_error',
    entropy_coeff=0.01, # Updated from entropy_coef
    critic_coeff=1.0,   # Updated from critic_coef
    normalize_advantage=True, # Important for PPO stability
    recurrent_state_keys={'hidden_state': 'hidden_state', 'hidden_state_value': 'hidden_state_value'} # Specify recurrent states for both actor and critic
).to(device)

# Workaround for AttributeError: 'ClipPPOLoss' object has no attribute 'in_keys'
# LossModule itself does not have in_keys/out_keys, but the _functional_module_forward_decorator
# expects them on any decorated nn.Module that's not a TensorDictModule.
# By defining empty lists, we satisfy the attribute check.
loss_module.in_keys = []
loss_module.out_keys = []

# Explicitly set the tensor_keys for action and action_log_prob on the loss_module
# This is still needed for ClipPPOLoss to find the keys, even with ProbabilisticActor.
loss_module.tensor_keys.action = ('agents', 'action')
loss_module.tensor_keys.sample_log_prob = ('agents', 'action_log_prob')


# Optimizers
optimizer_actor_critic = optim.Adam(loss_module.parameters(), lr=lr)
optimizer_forecaster = optim.Adam(forecaster.parameters(), lr=lr)

# Scheduler (optional, but good practice)
scheduler_actor_critic = torch.optim.lr_scheduler.CosineAnnealingLR(
    optimizer_actor_critic, T_max=total_frames // frames_per_batch
)
scheduler_forecaster = torch.optim.lr_scheduler.CosineAnnealingLR(
    optimizer_forecaster, T_max=total_frames // frames_per_batch
)

print("PPO Loss, Optimizers, and Schedulers initialized.")

for i, tensordict_data in enumerate(collector):
    # Ensure data is on the correct device for processing
    tensordict_data = tensordict_data.to(device)

    # Manually propagate hidden_state_value to the 'next' tensordict for GAE's value_network call.
    # This is necessary because SyncDataCollector does not handle recurrent_state_keys in this environment setup.
    if 'hidden_state_value' in tensordict_data.keys() and 'next' in tensordict_data.keys():
        tensordict_data['next', 'hidden_state_value'] = tensordict_data['hidden_state_value']

    # Manually add a placeholder for 'state_value' in 'next' tensordict for GAE's internal stacking compatibility.
    # GAE will later overwrite this with the actual computed next_value.
    if 'state_value' in tensordict_data.keys() and 'next' in tensordict_data.keys():
        if 'state_value' not in tensordict_data['next'].keys():
            dummy_state_value_shape = tensordict_data['next'].batch_size + tensordict_data['state_value'].shape[-2:]
            tensordict_data['next', 'state_value'] = torch.zeros(
                dummy_state_value_shape,
                dtype=tensordict_data['state_value'].dtype,
                device=tensordict_data.device
            )

    # --- Explicitly ensure consistency of shapes for GAE ---
    # Target shape: [num_envs, num_steps, 1, 1]

    # Normalize 'state_value' shape to [num_envs, num_steps, 1, 1]
    if 'state_value' in tensordict_data.keys():
        if tensordict_data['state_value'].ndim == 3: # Assuming [num_envs, num_steps, 1]
            tensordict_data['state_value'] = tensordict_data['state_value'].unsqueeze(-1)
    if 'next' in tensordict_data.keys() and 'state_value' in tensordict_data['next'].keys():
        if tensordict_data['next', 'state_value'].ndim == 3: # Assuming [num_envs, num_steps, 1]
            tensordict_data['next', 'state_value'] = tensordict_data['next', 'state_value'].unsqueeze(-1)

    # Normalize 'reward' shape to [num_envs, num_steps, 1, 1]
    if 'reward' in tensordict_data.keys():
        if tensordict_data['reward'].ndim == 2: # [num_envs, num_steps]
            tensordict_data['reward'] = tensordict_data['reward'].unsqueeze(-1).unsqueeze(-1)
        elif tensordict_data['reward'].ndim == 3: # [num_envs, num_steps, 1]
            tensordict_data['reward'] = tensordict_data['reward'].unsqueeze(-1)
    if 'next' in tensordict_data.keys() and 'reward' in tensordict_data['next'].keys():
        if tensordict_data['next', 'reward'].ndim == 2:
            tensordict_data['next', 'reward'] = tensordict_data['next', 'reward'].unsqueeze(-1).unsqueeze(-1)
        elif tensordict_data['next', 'reward'].ndim == 3:
            tensordict_data['next', 'reward'] = tensordict_data['next', 'reward'].unsqueeze(-1)

    # Normalize 'done' shape to [num_envs, num_steps, 1, 1]
    # If the shape is [num_envs, num_steps], it needs 2 unsqueezes
    # If the shape is [num_envs, num_steps, 1], it needs 1 unsqueeze
    if 'done' in tensordict_data.keys():
        if tensordict_data['done'].ndim == 2:
            tensordict_data['done'] = tensordict_data['done'].unsqueeze(-1).unsqueeze(-1)
        elif tensordict_data['done'].ndim == 3:
            tensordict_data['done'] = tensordict_data['done'].unsqueeze(-1)
    if 'next' in tensordict_data.keys() and 'done' in tensordict_data['next'].keys():
        if tensordict_data['next', 'done'].ndim == 2:
            tensordict_data['next', 'done'] = tensordict_data['next', 'done'].unsqueeze(-1).unsqueeze(-1)
        elif tensordict_data['next', 'done'].ndim == 3:
            tensordict_data['next', 'done'] = tensordict_data['next', 'done'].unsqueeze(-1)

    # Normalize 'terminated' shape to [num_envs, num_steps, 1, 1]
    if 'terminated' in tensordict_data.keys():
        if tensordict_data['terminated'].ndim == 2:
            tensordict_data['terminated'] = tensordict_data['terminated'].unsqueeze(-1).unsqueeze(-1)
        elif tensordict_data['terminated'].ndim == 3:
            tensordict_data['terminated'] = tensordict_data['terminated'].unsqueeze(-1)
    if 'next' in tensordict_data.keys() and 'terminated' in tensordict_data['next'].keys():
        if tensordict_data['next', 'terminated'].ndim == 2:
            tensordict_data['next', 'terminated'] = tensordict_data['next', 'terminated'].unsqueeze(-1).unsqueeze(-1)
        elif tensordict_data['next', 'terminated'].ndim == 3:
            tensordict_data['next', 'terminated'] = tensordict_data['next', 'terminated'].unsqueeze(-1)

    # Normalize 'truncated' shape to [num_envs, num_steps, 1, 1]
    if 'truncated' in tensordict_data.keys():
        if tensordict_data['truncated'].ndim == 2:
            tensordict_data['truncated'] = tensordict_data['truncated'].unsqueeze(-1).unsqueeze(-1)
        elif tensordict_data['truncated'].ndim == 3:
            tensordict_data['truncated'] = tensordict_data['truncated'].unsqueeze(-1)
    if 'next' in tensordict_data.keys() and 'truncated' in tensordict_data['next'].keys():
        if tensordict_data['next', 'truncated'].ndim == 2:
            tensordict_data['next', 'truncated'] = tensordict_data['next', 'truncated'].unsqueeze(-1).unsqueeze(-1)
        elif tensordict_data['next', 'truncated'].ndim == 3:
            tensordict_data['next', 'truncated'] = tensordict_data['next', 'truncated'].unsqueeze(-1)

    # Debugging print statements to verify shapes after adjustments
    print(f"\nShapes *after* adjustments and *before* adv_module (Iteration {i}):")
    if 'state_value' in tensordict_data.keys():
        print(f"  tensordict_data['state_value'].shape: {tensordict_data['state_value'].shape}")
    if 'reward' in tensordict_data.keys():
        print(f"  tensordict_data['reward'].shape: {tensordict_data['reward'].shape}")
    if 'done' in tensordict_data.keys():
        print(f"  tensordict_data['done'].shape: {tensordict_data['done'].shape}")
    if 'terminated' in tensordict_data.keys():
        print(f"  tensordict_data['terminated'].shape: {tensordict_data['terminated'].shape}")
    if 'truncated' in tensordict_data.keys():
        print(f"  tensordict_data['truncated'].shape: {tensordict_data['truncated'].shape}")

    if 'next' in tensordict_data.keys():
        if 'state_value' in tensordict_data['next'].keys():
            print(f"  tensordict_data['next', 'state_value'].shape: {tensordict_data['next', 'state_value'].shape}")
        if 'reward' in tensordict_data['next'].keys():
            print(f"  tensordict_data['next', 'reward'].shape: {tensordict_data['next', 'reward'].shape}")
        if 'done' in tensordict_data['next'].keys():
            print(f"  tensordict_data['next', 'done'].shape: {tensordict_data['next', 'done'].shape}")
        if 'terminated' in tensordict_data['next'].keys():
            print(f"  tensordict_data['next', 'terminated'].shape: {tensordict_data['next', 'terminated'].shape}")
        if 'truncated' in tensordict_data['next'].keys():
            print(f"  tensordict_data['next', 'truncated'].shape: {tensordict_data['next', 'truncated'].shape}")

    # 1. Compute GAE Advantages.
    # The adv_module (CustomGAE with value_network=critic) will now internally handle calculating
    # state_value and next.state_value and propagating hidden_state_value due to recurrent_state_keys.
    with torch.no_grad():
        # GAE with value_network will automatically compute state_value and next.state_value
        # and handle recurrent_state_keys, so no manual computation here.
        adv_module(tensordict_data)

    # 2. Extract input for forecaster and train it (supervised learning)
    # The forecaster predicts future 'x' (prices)
    # We need to get the current 'x' and compare against future 'x' from tensordict_data
    current_x = tensordict_data.get(('agents', 'data', 'x')) # [num_envs, num_steps, num_agents, actual_node_feature_dim]
    current_edge_index = tensordict_data.get(('agents', 'data', 'edge_index')) # [num_envs, num_steps, 2, num_edges]
    current_batch_nodes = tensordict_data.get(('agents', 'data', 'batch')) # [num_envs, num_steps, num_agents]
    current_time = tensordict_data.get(('agents', 'data', 'time')) # [num_envs, num_steps, 1]
    current_graph_attributes = tensordict_data.get(('agents', 'data', 'graph_attributes')) # [num_envs, num_steps, graph_attr_dim]

    # For forecaster training, we need actual future data to serve as targets
    # The 'next' key in tensordict_data holds the observations for the next step
    # However, the forecaster needs 'forecast_horizon' steps into the future.
    # This is a simplification and would need adjustment for a true multi-step forecast target.
    target_x = tensordict_data.get(('next', 'agents', 'data', 'x')) # [num_envs, num_steps, num_agents, actual_node_feature_dim]

    # Temporarily reshape tensordict_data to treat num_steps as batch for forecaster
    # (num_envs * num_steps) as batch size
    num_envs_val, num_steps_val = tensordict_data.batch_size # Use local variables to avoid shadowing globals
    forecaster_input_td = tensordict_data.select(
        ('agents', 'data', 'x'),
        ('agents', 'data', 'edge_index'),
        ('agents', 'data', 'batch'),
        ('agents', 'data', 'time'),
        ('agents', 'data', 'graph_attributes'),
        'hidden_state_forecast' # From previous step's output
    ).reshape(num_envs_val * num_steps_val)

    # Run forecaster on collected data
    forecast_td = forecaster(forecaster_input_td.clone())
    predicted_forecast = forecast_td.get('forecast') # [num_envs * num_steps, 1, num_agents, forecast_horizon]

    # Correct the reshape using actual_node_feature_dim
    target_x_flat = target_x.reshape(num_envs_val * num_steps_val, num_agents, actual_node_feature_dim)

    # Calculate MSE loss for the forecaster (predicting immediate next step)
    # Take only the first step of the forecast for the simplified target
    # Squeeze out the extra dimension at index 1 from predicted_forecast before slicing
    forecaster_loss = nn.functional.mse_loss(predicted_forecast.squeeze(1)[:, :, 0], target_x_flat.squeeze(-1))

    # Optimize forecaster
    optimizer_forecaster.zero_grad()
    forecaster_loss.backward()
    optimizer_forecaster.step()
    scheduler_forecaster.step()

    # 3. PPO Optimization (Actor-Critic)
    for _ in range(num_epochs):
        # Shuffle and split data into minibatches
        # Manually create minibatches by shuffling indices
        flat_tensordict_data = tensordict_data.reshape(-1) # Flatten both num_envs and num_steps
        data_size = len(flat_tensordict_data)
        # Create a shuffled list of indices for minibatches
        shuffled_indices = torch.randperm(data_size, device=device)

        for start_idx in range(0, data_size, minibatch_size):
            end_idx = min(start_idx + minibatch_size, data_size)
            minibatch_indices = shuffled_indices[start_idx:end_idx]
            minibatch = flat_tensordict_data[minibatch_indices]

            # Compute PPO loss
            loss_td = loss_module(minibatch)

            actor_loss = loss_td['loss_critic']
            critic_loss = loss_td['loss_critic']
            entropy_loss = loss_td['loss_entropy']
            total_ppo_loss = actor_loss + critic_loss + entropy_loss

            # Optimize actor-critic
            optimizer_actor_critic.zero_grad()
            total_ppo_loss.backward()
            torch.nn.utils.clip_grad_norm_(loss_module.parameters(), max_grad_norm)
            optimizer_actor_critic.step()
