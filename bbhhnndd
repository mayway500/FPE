# Workaround for AttributeError: 'ClipPPOLoss' object has no attribute 'in_keys'
# LossModule itself does not have in_keys/out_keys, but the _functional_module_forward_decorator
# expects them on any decorated nn.Module that's not a TensorDictModule.
