    hidden_rnn_dim=hidden_rnn_dim, # Pass hidden_rnn_dim to ForecastingBase
    device=device
).to(device)

# 2. Wrap policy_module_nn in a TensorDictModule that outputs logits AND hidden_state
actor_policy_td_module = TensorDictModule(
    module=policy_module_nn,
    in_keys=policy_in_keys_list, # This includes 'hidden_state' as input
    out_keys=['logits', 'hidden_state'] # This needs to output 'hidden_state' as well
).to(device)

# Construct the correct 1D nvec for Custom_MultiCategorical
# It should be a 1D tensor where each element is the number of categories for each individual action
correct_unbatched_nvec = torch.full(
